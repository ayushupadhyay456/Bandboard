# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FLASK_ENV=development          # development | production

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default dev)
DATABASE_URL=sqlite:///bandboard.db
# PostgreSQL (production example)
# DATABASE_URL=postgresql://user:password@localhost:5432/bandboard

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Cache DB (separate logical DB from task queue)
REDIS_CACHE_URL=redis://localhost:6379/1

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Email (for notifications) ────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bandboard.io

# ─── Cloud Storage (AWS S3) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=bandboard-media
AWS_S3_REGION=us-east-1
# Max upload size in bytes (default 50 MB)
MAX_UPLOAD_SIZE=52428800

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
# Set to "false" to disable ES and fall back to SQL LIKE search
ELASTICSEARCH_ENABLED=true

# ─── Geolocation ──────────────────────────────────────────────────────────────
# Google Maps API key for geocoding
GOOGLE_MAPS_API_KEY=your-google-maps-key
